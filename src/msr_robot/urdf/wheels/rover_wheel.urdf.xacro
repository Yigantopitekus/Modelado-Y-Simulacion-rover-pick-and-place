<?xml version="1.0"?>
<!-- created with Phobos 1.0.1 "Capricious Choutengan" -->
<robot name="robot" xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro name="rover_wheel" params="prefix parent *origin">
    <joint name="${prefix}wheel_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${prefix}wheel_link"/>
      <xacro:insert_block name="origin"/>
      <axis xyz="0 0 1"/>
    </joint>

    <link name="${prefix}wheel_link">
      <collision name="${prefix}wheel_collision">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://msr_robot/meshes/dae/Torus.001.dae" scale="0.29444 0.29444 0.62774"/>
        </geometry>
        <surface>
            <friction>
                <ode>
                    <mu>1.000000</mu>
                    <mu2>1.000000</mu2>
                    <fdir1>0.000000 0.000000 1.000000</fdir1>
                    <slip1>0.0050000</slip1>
                    <slip2>0.0050000</slip2>
                </ode>
            </friction>
        </surface>
      </collision>

      <inertial>
        <inertia ixx="0.18734" ixy="0" ixz="0" iyy="0.10770" iyz="0" izz="0.10770"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <mass value="3.0"/>
      </inertial>

      <visual name="${prefix}wheel_visual">
        <material name="Material"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://msr_robot/meshes/dae/Torus.001.dae" scale="0.29444 0.29444 0.62774"/>
        </geometry>
      </visual>
    </link>

    <transmission name="${prefix}_wheel_joint_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}wheel_joint">
          <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}wheel_joint_motor">
          <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>

    <gazebo reference="${prefix}wheel_link">
        <mu1>5</mu1>
        <mu2>5</mu2>
    </gazebo>
  </xacro:macro>
</robot>